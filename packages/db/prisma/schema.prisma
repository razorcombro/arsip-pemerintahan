generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ArchiveStatus {
  DRAFT
  ACTIVE
  INACTIVE
  DESTROYED
}

enum SecurityLevel {
  BIASA
  TERBATAS
  RAHASIA
  SANGAT_RAHASIA
}

model Unit {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  users     User[]
  archives  Archive[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String      @id @default(cuid())
  fullName     String
  email        String      @unique
  username     String      @unique
  passwordHash String
  status       UserStatus  @default(ACTIVE)
  unitId       String?
  unit         Unit?       @relation(fields: [unitId], references: [id])
  roles        UserRole[]
  auditLogs     AuditLog[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Role {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  users     UserRole[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

model Classification {
  id                String    @id @default(cuid())
  code              String    @unique
  name              String
  activeRetention   Int
  inactiveRetention Int
  archives          Archive[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Archive {
  id                String         @id @default(cuid())
  archiveNumber     String         @unique
  letterNumber      String?
  title             String
  summary           String?
  createdByUnitId   String
  createdByUnit     Unit           @relation(fields: [createdByUnitId], references: [id])
  classificationId  String
  classification    Classification @relation(fields: [classificationId], references: [id])
  securityLevel     SecurityLevel  @default(BIASA)
  status            ArchiveStatus  @default(DRAFT)
  keywords          String[]
  version           Int            @default(1)
  files             ArchiveFile[]
  auditLogs      AuditLog[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model ArchiveFile {
  id             String   @id @default(cuid())
  archiveId      String
  archive        Archive  @relation(fields: [archiveId], references: [id], onDelete: Cascade)
  originalName   String
  storedName     String
  mimeType       String
  sizeBytes      BigInt
  storageKey     String   @unique
  checksumSha256 String
  uploadedAt     DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  archiveId   String?
  action      String
  entityType  String
  entityId    String?
  description String?
  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id])
  archive     Archive? @relation(fields: [archiveId], references: [id])
}
